---
import Layout from '../../layouts/Layout.astro';

const articles = [
  {
    slug: 'astro-vs-nextjs',
    category: 'Web Dev',
    categoryColor: '#4a8abf',
    title: 'Come scegliere il framework giusto: Astro vs Next.js',
    excerpt:
      'Astro e Next.js sono i due framework di riferimento per lo sviluppo web moderno in Sicilia e in Italia. Entrambi eccellenti, ma con punti di forza diversi: Astro eccelle in performance e SEO tecnica per siti statici, Next.js è la scelta ideale per applicazioni dinamiche. Ti aiutiamo a scegliere in base al tuo progetto.',
    date: '2026-03-15',
    readTime: '6 min',
  },
  {
    slug: 'local-seo-palermo-2026',
    category: 'SEO',
    categoryColor: '#4a9e6e',
    title: 'Local SEO a Palermo: guida completa 2026',
    excerpt:
      'Come posizionare la tua attività su Google Maps e nelle ricerche locali di Palermo. Dalla scheda Google Business Profile alle citazioni locali, tutto quello che devi sapere.',
    date: '2026-02-28',
    readTime: '9 min',
  },
  {
    slug: 'core-web-vitals',
    category: 'Performance',
    categoryColor: '#c8703a',
    title: 'Core Web Vitals: cosa sono e perché contano',
    excerpt:
      'LCP, FID, CLS: i tre indicatori che Google usa per valutare l\'esperienza utente del tuo sito. Come misurarli, interpretarli e migliorarli per scalare le SERP.',
    date: '2026-02-10',
    readTime: '7 min',
  },
  {
    slug: 'quanto-costa-sito-web',
    category: 'Business',
    categoryColor: '#9a6abf',
    title: 'Quanto costa un sito web professionale?',
    excerpt:
      'La risposta onesta alla domanda più frequente. Scopri i range di prezzo reali per siti vetrina, e-commerce e landing page nel 2026, e cosa determina il costo finale.',
    date: '2026-01-20',
    readTime: '5 min',
  },
];
---

<Layout
  title="Blog Web Design & SEO — WebCreator Studio"
  description="Guide su Astro, Next.js, SEO tecnica e web design moderno. Articoli pratici scritti da WebCreator Studio Palermo."
>

  <!-- HERO -->
  <section class="page-hero">
    <div class="container page-hero-inner">
      <span class="section-label">Risorse & Guide</span>
      <h1>Blog — Web Design & SEO</h1>
      <p class="page-hero-desc">
        Articoli pratici su web design, SEO, performance e digital marketing.
        Scritti da chi lavora sul campo ogni giorno.
      </p>
    </div>
  </section>

  <!-- ARTICLES -->
  <section class="blog-section">
    <div class="container">
      <div class="articles-grid reveal-stagger">
        {articles.map((a) => (
          <article class="article-card">
            <div class="article-top">
              <span
                class="article-category"
                style={`background: ${a.categoryColor}22; color: ${a.categoryColor};`}
              >
                {a.category}
              </span>
              <span class="article-meta">{a.readTime} · {a.date}</span>
            </div>
            <h2 class="article-title">
              <a href={`/blog/${a.slug}`}>{a.title}</a>
            </h2>
            <p class="article-excerpt">{a.excerpt}</p>
            <a href={`/blog/${a.slug}`} class="article-link">Leggi →</a>
          </article>
        ))}
      </div>

      <!-- External blog note -->
      <div class="external-note reveal">
        <p>
          Vuoi altri articoli? Visita il nostro blog principale su
          <a
            href="https://webcreator-seo.it/it/blog"
            target="_blank"
            rel="noopener"
            class="ext-link"
          >
            webcreator-seo.it/it/blog
          </a>
          per la guida completa al web design e SEO in Sicilia.
        </p>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* PAGE HERO */
  .page-hero {
    padding: 80px 0 60px;
    border-bottom: 1px solid var(--border);
  }

  .page-hero-inner {
    max-width: 720px;
  }

  .page-hero-inner h1 {
    font-size: clamp(2rem, 4.5vw, 3.5rem);
    margin-bottom: 1.25rem;
  }

  .page-hero-desc {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.7;
    font-family: var(--sans);
  }

  /* BLOG SECTION */
  .blog-section {
    padding: 80px 0 100px;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  .article-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: border-color 0.25s ease, transform 0.25s ease;
  }

  .article-card:hover {
    border-color: var(--border-strong);
    transform: translateY(-3px);
  }

  .article-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .article-category {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.65rem;
    border-radius: 100px;
    font-family: var(--sans);
  }

  .article-meta {
    font-size: 0.75rem;
    color: var(--text-subtle);
    font-family: var(--sans);
    white-space: nowrap;
  }

  .article-title {
    font-family: var(--serif);
    font-size: 1.3rem;
    font-weight: 400;
    line-height: 1.3;
  }

  .article-title a {
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s;
  }

  .article-title a:hover {
    color: var(--accent);
  }

  .article-excerpt {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.7;
    flex: 1;
    font-family: var(--sans);
  }

  .article-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    font-family: var(--sans);
    transition: opacity 0.2s;
    align-self: flex-start;
  }

  .article-link:hover {
    opacity: 0.75;
  }

  /* EXTERNAL NOTE */
  .external-note {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem 2rem;
    background: var(--bg2);
  }

  .external-note p {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.65;
    font-family: var(--sans);
  }

  .ext-link {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: opacity 0.2s;
  }

  .ext-link:hover {
    opacity: 0.75;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
