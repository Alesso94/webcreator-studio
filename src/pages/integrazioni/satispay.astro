---
import Layout from '../../layouts/Layout.astro';

const products = [
  { id:1, name:"Olio EVO DOP Sicilia 500ml",      price:18.50, emoji:"🫒", badge:"Bio" },
  { id:2, name:"Pesto di Pistacchio Bronte 180g",  price:12.90, emoji:"🌿", badge:"Artigianale" },
  { id:3, name:"Candela Profumata al Bergamotto",  price:24.00, emoji:"🕯️", badge:"Handmade" },
  { id:4, name:"Collana Argento 925 Fatta a Mano", price:49.00, emoji:"💍", badge:"Limited" },
  { id:5, name:"Vino Nero d'Avola DOC 2022",       price:14.00, emoji:"🍷", badge:null },
  { id:6, name:"Sapone Naturale al Latte d'Asina", price: 9.90, emoji:"🧼", badge:"Vegan" },
];
---

<Layout
  title="Demo Satispay — WebCreator Studio"
  description="Demo interattiva di integrazione Satispay per e-commerce. Scopri come WebCreator Studio integra Satispay nel tuo shop online."
  canonical="https://webcreator-studio.it/integrazioni/satispay"
>

<!-- DEMO BANNER -->
<div class="demo-banner">
  <span class="demo-tag">DEMO</span>
  Simulazione di integrazione Satispay — nessun pagamento reale viene effettuato.
  <a href="/contatti">Vuoi integrarlo nel tuo shop? →</a>
</div>

<!-- HERO -->
<section class="sati-hero">
  <div class="container">
    <span class="section-label">Integrazione Pagamenti</span>
    <h1>Paga con <em>Satispay.</em></h1>
    <p class="hero-desc">
      Aggiungi Satispay al tuo e-commerce: zero commissioni per il cliente,
      pagamento istantaneo, QR code e deep link mobile. Integrazione nativa
      con WooCommerce, Shopify o stack custom.
    </p>
  </div>
</section>

<!-- SHOP DEMO -->
<section class="sati-shop">
  <div class="container">
    <div class="shop-wrap">

      <!-- Products -->
      <div class="products-col">
        <p class="shop-label">Shop di esempio — aggiungi prodotti e prova il checkout</p>
        <div class="products-grid" id="productsGrid">
          {products.map(p => (
            <div class="product-card" id={`card-${p.id}`} data-id={p.id} data-name={p.name} data-price={p.price}>
              <div class="product-top">
                <span class="product-emoji">{p.emoji}</span>
                {p.badge && <span class="product-badge">{p.badge}</span>}
              </div>
              <div class="product-name">{p.name}</div>
              <div class="product-footer">
                <span class="product-price">€{p.price.toFixed(2)}</span>
                <button class="product-add-btn" data-id={p.id}>+ Aggiungi</button>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Cart Sidebar -->
      <aside class="cart-sidebar" id="cartSidebar">
        <div class="cart-header">
          <span class="cart-title-text">Carrello</span>
          <span class="cart-count-badge" id="sidebarCartCount">0</span>
        </div>
        <div id="cartEmpty" class="cart-empty">Nessun prodotto aggiunto</div>
        <div id="cartItems" class="cart-items" style="display:none"></div>
        <div id="cartFooter" style="display:none">
          <hr class="cart-divider" />
          <div class="cart-total-row">
            <span>Totale</span>
            <span id="cartTotal">€0,00</span>
          </div>
          <button class="satispay-btn" id="payBtn">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <circle cx="10" cy="10" r="10" fill="white" fill-opacity="0.2"/>
              <path d="M10 4C6.686 4 4 6.686 4 10C4 13.314 6.686 16 10 16C13.314 16 16 13.314 16 10C16 6.686 13.314 4 10 4ZM10.8 13.2H9.2V11.6H10.8V13.2ZM10.8 10H9.2V6.8H10.8V10Z" fill="white"/>
            </svg>
            Paga con Satispay
          </button>
          <p class="cart-note">Zero commissioni · Pagamento istantaneo</p>
        </div>
      </aside>

    </div>
  </div>
</section>

<!-- INFO STRIP -->
<section class="sati-info">
  <div class="container">
    <div class="info-grid">
      <div class="info-item">
        <div class="info-icon">💸</div>
        <div>
          <h3>Zero commissioni</h3>
          <p>I clienti non pagano nulla in più. Il merchant paga solo €0,20 per ordini sopra €10.</p>
        </div>
      </div>
      <div class="info-item">
        <div class="info-icon">⚡</div>
        <div>
          <h3>Pagamento istantaneo</h3>
          <p>Il bonifico arriva in tempo reale sul conto Satispay Business del merchant.</p>
        </div>
      </div>
      <div class="info-item">
        <div class="info-icon">📱</div>
        <div>
          <h3>QR code & deep link</h3>
          <p>Desktop: scansiona il QR. Mobile: apre direttamente l'app Satispay.</p>
        </div>
      </div>
      <div class="info-item">
        <div class="info-icon">🔌</div>
        <div>
          <h3>API REST + webhook</h3>
          <p>Integrazione nativa con Next.js, WooCommerce, Shopify e qualsiasi stack custom.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="sati-cta">
  <div class="container sati-cta-inner">
    <div>
      <h2>Vuoi Satispay nel tuo e-commerce?</h2>
      <p>Lo integriamo in qualsiasi piattaforma — WooCommerce, Shopify o custom.</p>
    </div>
    <a href="/contatti" class="btn btn-primary">Parliamo del tuo progetto →</a>
  </div>
</section>

</Layout>

<!-- PAYMENT MODAL (fuori dal Layout slot per il z-index) -->
<div class="modal-backdrop" id="modalBackdrop" role="dialog" aria-modal="true" aria-label="Pagamento Satispay">
  <div class="modal" id="modal">

    <!-- Step 1: Payment -->
    <div id="stepPayment">
      <div class="modal-header">
        <div class="modal-header-logo">💸</div>
        <div class="modal-header-text">
          <h2>Paga con Satispay</h2>
          <p>Shop Demo — webcreator-studio.it</p>
        </div>
      </div>
      <div class="modal-body">
        <div class="payment-tabs">
          <button class="tab-btn active" id="tabQR" data-tab="qr">💻 QR Code</button>
          <button class="tab-btn" id="tabMobile" data-tab="mobile">📱 App Mobile</button>
        </div>

        <!-- QR Panel -->
        <div id="panelQR" class="qr-panel">
          <div class="amount-label">Importo da pagare</div>
          <div class="amount-value" id="modalAmount">€0,00</div>
          <div class="qr-wrap">
            <svg width="160" height="160" viewBox="0 0 160 160" xmlns="http://www.w3.org/2000/svg">
              <rect x="8" y="8" width="44" height="44" rx="4" fill="#e30613"/>
              <rect x="14" y="14" width="32" height="32" rx="2" fill="white"/>
              <rect x="20" y="20" width="20" height="20" rx="1" fill="#e30613"/>
              <rect x="108" y="8" width="44" height="44" rx="4" fill="#e30613"/>
              <rect x="114" y="14" width="32" height="32" rx="2" fill="white"/>
              <rect x="120" y="20" width="20" height="20" rx="1" fill="#e30613"/>
              <rect x="8" y="108" width="44" height="44" rx="4" fill="#e30613"/>
              <rect x="14" y="114" width="32" height="32" rx="2" fill="white"/>
              <rect x="20" y="120" width="20" height="20" rx="1" fill="#e30613"/>
              <g fill="#e30613" opacity="0.85">
                <rect x="60" y="8" width="8" height="8"/><rect x="72" y="8" width="8" height="8"/><rect x="84" y="8" width="8" height="8"/>
                <rect x="60" y="20" width="8" height="8"/><rect x="84" y="20" width="8" height="8"/>
                <rect x="60" y="32" width="8" height="8"/><rect x="72" y="32" width="8" height="8"/>
                <rect x="8" y="60" width="8" height="8"/><rect x="20" y="60" width="8" height="8"/><rect x="44" y="60" width="8" height="8"/>
                <rect x="8" y="72" width="8" height="8"/><rect x="32" y="72" width="8" height="8"/>
                <rect x="20" y="84" width="8" height="8"/><rect x="44" y="84" width="8" height="8"/>
                <rect x="60" y="60" width="8" height="8"/><rect x="72" y="60" width="8" height="8"/><rect x="84" y="60" width="8" height="8"/><rect x="96" y="60" width="8" height="8"/>
                <rect x="60" y="72" width="8" height="8"/><rect x="84" y="72" width="8" height="8"/>
                <rect x="72" y="84" width="8" height="8"/><rect x="96" y="84" width="8" height="8"/>
                <rect x="108" y="60" width="8" height="8"/><rect x="132" y="60" width="8" height="8"/><rect x="144" y="60" width="8" height="8"/>
                <rect x="120" y="72" width="8" height="8"/><rect x="144" y="72" width="8" height="8"/>
                <rect x="108" y="84" width="8" height="8"/><rect x="132" y="84" width="8" height="8"/>
                <rect x="60" y="108" width="8" height="8"/><rect x="72" y="108" width="8" height="8"/>
                <rect x="84" y="108" width="8" height="8"/><rect x="108" y="108" width="8" height="8"/><rect x="132" y="108" width="8" height="8"/>
                <rect x="60" y="120" width="8" height="8"/><rect x="84" y="120" width="8" height="8"/><rect x="96" y="120" width="8" height="8"/>
                <rect x="120" y="120" width="8" height="8"/><rect x="144" y="120" width="8" height="8"/>
                <rect x="60" y="132" width="8" height="8"/><rect x="72" y="132" width="8" height="8"/><rect x="96" y="132" width="8" height="8"/>
                <rect x="108" y="132" width="8" height="8"/><rect x="132" y="132" width="8" height="8"/>
                <rect x="60" y="144" width="8" height="8"/><rect x="84" y="144" width="8" height="8"/><rect x="120" y="144" width="8" height="8"/><rect x="144" y="144" width="8" height="8"/>
              </g>
              <rect x="66" y="66" width="28" height="28" rx="4" fill="white"/>
              <rect x="70" y="70" width="20" height="20" rx="2" fill="#e30613"/>
              <rect x="76" y="74" width="8" height="2" fill="white"/>
              <rect x="76" y="78" width="8" height="8" fill="white"/>
            </svg>
          </div>
          <div class="timer-wrap">
            <div class="timer-dot"></div>
            <span>Il codice scade tra <span id="timer">02:00</span></span>
          </div>
          <button class="modal-simulate-btn" id="simulateBtn">✓ Simula pagamento confermato</button>
        </div>

        <!-- Mobile Panel -->
        <div id="panelMobile" class="mobile-panel" style="display:none">
          <div class="amount-label">Importo da pagare</div>
          <div class="amount-value" id="modalAmountMobile">€0,00</div>
          <div class="phone-mockup">
            <div class="phone-screen">
              <div class="phone-sati-logo">💸</div>
              <div class="phone-amount" id="phoneAmount">€0,00</div>
              <div class="phone-merchant">Shop Demo</div>
              <div class="phone-confirm-btn">Conferma ✓</div>
            </div>
          </div>
          <a href="#" class="deeplink-btn" id="deeplinkBtn" onclick="return false;">
            📱 Apri l'app Satispay
          </a>
          <p class="deeplink-note">Il deep link aprirebbe l'app Satispay con il pagamento precaricato.</p>
          <button class="modal-simulate-btn" id="simulateBtnMobile">✓ Simula pagamento confermato</button>
        </div>

        <button class="modal-close-btn" id="modalCloseBtn">Annulla pagamento</button>
      </div>
    </div>

    <!-- Step 2: Success -->
    <div id="stepSuccess" style="display:none">
      <div class="success-step">
        <div class="success-icon">✓</div>
        <div class="success-title">Pagamento ricevuto!</div>
        <div class="success-sub">
          Il pagamento è stato confermato istantaneamente.<br/>
          I fondi sono già disponibili sul conto Satispay Business.
        </div>
        <div class="success-detail">
          <div class="success-row"><span>Importo</span><span id="successAmount">€0,00</span></div>
          <div class="success-row"><span>Metodo</span><span>Satispay</span></div>
          <div class="success-row"><span>Stato</span><span class="success-confirmed">✓ Confermato</span></div>
          <div class="success-row"><span>Commissione</span><span>€0,20</span></div>
          <div class="success-row"><span>Riferimento</span><span id="successRef">STW-000000</span></div>
        </div>
        <button class="success-close-btn" id="successCloseBtn">Chiudi e svuota carrello</button>
      </div>
    </div>

  </div>
</div>

<style>
  /* ===== SATISPAY RED (brand) ===== */
  :root {
    --sati-red:     #e30613;
    --sati-red-dim: rgba(227,6,19,0.10);
    --sati-red-h:   #c8000f;
  }

  /* ===== DEMO BANNER ===== */
  .demo-banner {
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    text-align: center;
    padding: 10px 16px;
    font-size: 0.82rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .demo-tag {
    background: var(--sati-red);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: .08em;
    padding: 2px 8px;
    border-radius: 4px;
  }
  .demo-banner a { color: var(--accent); text-decoration: none; font-weight: 500; }
  .demo-banner a:hover { text-decoration: underline; }

  /* ===== HERO ===== */
  .sati-hero {
    padding: 72px 0 48px;
    border-bottom: 1px solid var(--border);
  }
  .sati-hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1.12;
    margin-bottom: 16px;
  }
  .sati-hero h1 em { font-style: italic; color: var(--accent); }
  .hero-desc {
    font-size: 1rem;
    color: var(--text-muted);
    max-width: 560px;
    line-height: 1.7;
  }

  /* ===== SHOP SECTION ===== */
  .sati-shop { padding: 56px 0 64px; }

  .shop-wrap {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 32px;
    align-items: start;
  }
  @media (max-width: 768px) { .shop-wrap { grid-template-columns: 1fr; } }

  .shop-label {
    font-size: 0.78rem;
    color: var(--text-subtle);
    margin-bottom: 20px;
    font-style: italic;
  }

  /* ===== PRODUCT GRID ===== */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 16px;
  }

  .product-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: border-color .2s, transform .2s;
    cursor: default;
  }
  .product-card:hover { border-color: var(--border-strong); transform: translateY(-2px); }
  .product-card.in-cart { border-color: var(--accent); }

  .product-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
  }
  .product-emoji { font-size: 2rem; line-height: 1; }
  .product-badge {
    font-size: 0.63rem;
    font-weight: 600;
    letter-spacing: .07em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: var(--bg3);
    border: 1px solid var(--border);
    padding: 2px 7px;
    border-radius: 20px;
    white-space: nowrap;
  }

  .product-name {
    font-size: 0.875rem;
    color: var(--text);
    line-height: 1.4;
    flex: 1;
  }

  .product-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-top: auto;
  }
  .product-price {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text);
  }
  .product-add-btn {
    background: var(--bg3);
    border: 1px solid var(--border-strong);
    color: var(--text-muted);
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 0.78rem;
    font-family: var(--sans);
    cursor: pointer;
    transition: border-color .2s, color .2s;
    white-space: nowrap;
  }
  .product-add-btn:hover { border-color: var(--accent); color: var(--accent); }
  .product-card.in-cart .product-add-btn { border-color: var(--accent); color: var(--accent); }

  /* ===== CART SIDEBAR ===== */
  .cart-sidebar {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px;
    position: sticky;
    top: 80px;
  }
  .cart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }
  .cart-title-text { font-size: 0.95rem; font-weight: 600; }
  .cart-count-badge {
    background: var(--bg3);
    border: 1px solid var(--border-strong);
    color: var(--text-muted);
    border-radius: 50%;
    width: 22px;
    height: 22px;
    font-size: 0.72rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cart-empty {
    color: var(--text-subtle);
    font-size: 0.83rem;
    text-align: center;
    padding: 20px 0;
    font-style: italic;
  }
  .cart-items { display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px; }
  .cart-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.82rem;
  }
  .cart-item-name { flex: 1; color: var(--text-muted); line-height: 1.3; }
  .cart-item-price { font-weight: 600; white-space: nowrap; }
  .cart-item-remove {
    background: none; border: none;
    color: var(--text-subtle); cursor: pointer;
    font-size: 0.9rem; padding: 0 2px;
    transition: color .2s;
  }
  .cart-item-remove:hover { color: var(--sati-red); }

  .cart-divider { border: none; border-top: 1px solid var(--border-strong); margin: 12px 0; }
  .cart-total-row {
    display: flex; justify-content: space-between;
    font-weight: 700; font-size: 1rem;
    margin-bottom: 16px;
  }

  .satispay-btn {
    width: 100%;
    background: var(--sati-red);
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 12px;
    font-size: 0.9rem;
    font-weight: 700;
    font-family: var(--sans);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: background .2s, transform .15s;
  }
  .satispay-btn:hover { background: var(--sati-red-h); transform: translateY(-1px); }

  .cart-note {
    font-size: 0.7rem;
    color: var(--text-subtle);
    text-align: center;
    margin-top: 8px;
  }

  /* ===== INFO GRID ===== */
  .sati-info {
    padding: 56px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 32px;
  }
  .info-item { display: flex; align-items: flex-start; gap: 14px; }
  .info-icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 2px; }
  .info-item h3 {
    font-family: var(--sans);
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 6px;
    color: var(--text);
  }
  .info-item p { font-size: 0.8rem; color: var(--text-muted); line-height: 1.6; }

  /* ===== CTA ===== */
  .sati-cta { padding: 64px 0; }
  .sati-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    flex-wrap: wrap;
  }
  .sati-cta h2 { font-size: 1.6rem; margin-bottom: 8px; }
  .sati-cta p { color: var(--text-muted); font-size: 0.9rem; }

  /* ===== MODAL ===== */
  .modal-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.75);
    z-index: 10001;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }
  .modal-backdrop.open { display: flex; }

  .modal {
    background: var(--bg2);
    border: 1px solid var(--border-strong);
    border-radius: 12px;
    width: 100%;
    max-width: 420px;
    overflow: hidden;
    animation: modalIn .25s ease;
  }
  @keyframes modalIn {
    from { opacity: 0; transform: translateY(16px) scale(.97); }
    to   { opacity: 1; transform: none; }
  }

  .modal-header {
    background: var(--sati-red);
    padding: 18px 22px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .modal-header-logo {
    width: 38px; height: 38px;
    background: rgba(255,255,255,.15);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem;
  }
  .modal-header-text h2 { font-family: var(--sans); font-size: 0.95rem; font-weight: 700; color: #fff; }
  .modal-header-text p  { font-size: 0.78rem; color: rgba(255,255,255,.7); margin-top: 2px; }

  .modal-body { padding: 22px; }

  .payment-tabs {
    display: flex;
    background: var(--bg3);
    border-radius: 8px;
    padding: 3px;
    gap: 3px;
    margin-bottom: 20px;
  }
  .tab-btn {
    flex: 1;
    background: none;
    border: none;
    color: var(--text-muted);
    border-radius: 6px;
    padding: 7px 10px;
    font-size: 0.8rem;
    font-family: var(--sans);
    cursor: pointer;
    transition: background .2s, color .2s;
  }
  .tab-btn.active {
    background: var(--bg2);
    color: var(--text);
    box-shadow: 0 1px 3px rgba(0,0,0,.3);
  }

  /* QR panel */
  .qr-panel { text-align: center; }
  .qr-wrap {
    background: #fff;
    border-radius: 10px;
    padding: 14px;
    display: inline-block;
    margin-bottom: 14px;
  }
  .qr-wrap svg { display: block; }

  .amount-label { font-size: 0.75rem; color: var(--text-muted); margin-bottom: 4px; }
  .amount-value { font-size: 1.6rem; font-weight: 700; margin-bottom: 14px; }

  .timer-wrap {
    display: flex; align-items: center; justify-content: center;
    gap: 8px; font-size: 0.8rem; color: var(--text-muted);
    margin-bottom: 18px;
  }
  .timer-dot {
    width: 7px; height: 7px;
    background: var(--green);
    border-radius: 50%;
    animation: pulse 1.5s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }
  #timer { font-weight: 600; color: var(--text); }

  /* Mobile panel */
  .mobile-panel { text-align: center; }
  .phone-mockup {
    display: inline-block;
    background: var(--bg3);
    border: 2px solid var(--border-strong);
    border-radius: 24px;
    padding: 10px;
    margin-bottom: 14px;
    width: 160px;
  }
  .phone-screen {
    background: #fff;
    border-radius: 16px;
    padding: 14px 10px;
    text-align: center;
  }
  .phone-sati-logo { font-size: 1.4rem; margin-bottom: 4px; }
  .phone-amount    { font-size: 1rem; font-weight: 700; color: #111; }
  .phone-merchant  { font-size: 0.65rem; color: #888; margin: 2px 0 8px; }
  .phone-confirm-btn {
    background: var(--sati-red);
    color: #fff;
    border-radius: 6px;
    font-size: 0.68rem;
    font-weight: 700;
    padding: 6px 10px;
    width: 100%;
  }

  .deeplink-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--sati-red);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 11px 22px;
    font-size: 0.875rem;
    font-weight: 700;
    font-family: var(--sans);
    cursor: pointer;
    text-decoration: none;
    transition: background .2s;
    margin-bottom: 10px;
  }
  .deeplink-btn:hover { background: var(--sati-red-h); }
  .deeplink-note { font-size: 0.75rem; color: var(--text-muted); margin-bottom: 14px; }

  .modal-simulate-btn {
    width: 100%;
    background: none;
    border: 1px solid var(--border-strong);
    color: var(--text-muted);
    border-radius: 8px;
    padding: 10px;
    font-size: 0.8rem;
    font-family: var(--sans);
    cursor: pointer;
    transition: border-color .2s, color .2s;
    margin-top: 6px;
  }
  .modal-simulate-btn:hover { border-color: var(--green); color: var(--green); }

  .modal-close-btn {
    width: 100%;
    background: none;
    border: none;
    color: var(--text-subtle);
    font-size: 0.75rem;
    font-family: var(--sans);
    cursor: pointer;
    margin-top: 8px;
    padding: 6px;
    transition: color .2s;
  }
  .modal-close-btn:hover { color: var(--text-muted); }

  /* Success */
  .success-step { padding: 36px 22px; text-align: center; }
  .success-icon {
    width: 64px; height: 64px;
    background: rgba(74,158,110,0.12);
    border: 2px solid var(--green);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 18px;
    font-size: 1.8rem;
    color: var(--green);
  }
  .success-title { font-family: var(--serif); font-size: 1.3rem; margin-bottom: 8px; }
  .success-sub { color: var(--text-muted); font-size: 0.85rem; line-height: 1.6; margin-bottom: 20px; }
  .success-detail {
    background: var(--bg3);
    border-radius: 8px;
    padding: 14px;
    text-align: left;
    font-size: 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 18px;
  }
  .success-row { display: flex; justify-content: space-between; color: var(--text-muted); }
  .success-row span:last-child { color: var(--text); font-weight: 500; }
  .success-confirmed { color: var(--green) !important; }
  .success-close-btn {
    width: 100%;
    background: var(--sati-red);
    border: none;
    color: #fff;
    border-radius: 8px;
    padding: 12px;
    font-size: 0.875rem;
    font-weight: 700;
    font-family: var(--sans);
    cursor: pointer;
    transition: background .2s;
  }
  .success-close-btn:hover { background: var(--sati-red-h); }
</style>

<script>
  const cart = new Map();
  let timerInterval = null;
  let timerSeconds = 120;

  const productsGrid     = document.getElementById('productsGrid');
  const cartItems        = document.getElementById('cartItems');
  const cartEmpty        = document.getElementById('cartEmpty');
  const cartFooter       = document.getElementById('cartFooter');
  const cartTotal        = document.getElementById('cartTotal');
  const sidebarCartCount = document.getElementById('sidebarCartCount');
  const payBtn           = document.getElementById('payBtn');
  const modalBackdrop    = document.getElementById('modalBackdrop');
  const modalAmount      = document.getElementById('modalAmount');
  const modalAmountMobile= document.getElementById('modalAmountMobile');
  const phoneAmount      = document.getElementById('phoneAmount');
  const successAmount    = document.getElementById('successAmount');
  const successRef       = document.getElementById('successRef');
  const timerEl          = document.getElementById('timer');
  const stepPayment      = document.getElementById('stepPayment');
  const stepSuccess      = document.getElementById('stepSuccess');

  function fmt(n) { return '€' + n.toFixed(2).replace('.', ','); }
  function getTotal() { let t = 0; cart.forEach(i => t += i.price * i.qty); return t; }
  function getCount() { let c = 0; cart.forEach(i => c += i.qty); return c; }
  function randomRef() { return 'STW-' + Math.random().toString(36).slice(2,8).toUpperCase(); }

  function renderCart() {
    const count = getCount();
    const total = getTotal();
    sidebarCartCount.textContent = count;

    if (cart.size === 0) {
      cartEmpty.style.display  = '';
      cartItems.style.display  = 'none';
      cartFooter.style.display = 'none';
    } else {
      cartEmpty.style.display  = 'none';
      cartItems.style.display  = '';
      cartFooter.style.display = '';
      cartItems.innerHTML = '';
      cart.forEach((item, id) => {
        const row = document.createElement('div');
        row.className = 'cart-item';
        row.innerHTML = `
          <span class="cart-item-name">${item.name}${item.qty > 1 ? ` ×${item.qty}` : ''}</span>
          <span class="cart-item-price">${fmt(item.price * item.qty)}</span>
          <button class="cart-item-remove" data-id="${id}" aria-label="Rimuovi">✕</button>
        `;
        cartItems.appendChild(row);
      });
    }
    cartTotal.textContent = fmt(total);
  }

  function addToCart(id, name, price) {
    if (cart.has(id)) { cart.get(id).qty++; }
    else { cart.set(id, { name, price: parseFloat(price), qty: 1 }); }
    document.getElementById(`card-${id}`).classList.add('in-cart');
    const btn = document.querySelector(`.product-add-btn[data-id="${id}"]`);
    if (btn) btn.textContent = '✓ Aggiunto';
    renderCart();
  }

  function removeFromCart(id) {
    cart.delete(id);
    const card = document.getElementById(`card-${id}`);
    if (card) {
      card.classList.remove('in-cart');
      const btn = card.querySelector('.product-add-btn');
      if (btn) btn.textContent = '+ Aggiungi';
    }
    renderCart();
  }

  productsGrid.addEventListener('click', e => {
    const btn = e.target.closest('.product-add-btn');
    if (!btn) return;
    const card = btn.closest('.product-card');
    addToCart(card.dataset.id, card.dataset.name, card.dataset.price);
  });

  cartItems.addEventListener('click', e => {
    const btn = e.target.closest('.cart-item-remove');
    if (btn) removeFromCart(btn.dataset.id);
  });

  function startTimer() {
    timerSeconds = 120;
    clearInterval(timerInterval);
    timerEl.textContent = '02:00';
    timerEl.style.color = '';
    timerInterval = setInterval(() => {
      timerSeconds--;
      const m = String(Math.floor(timerSeconds / 60)).padStart(2, '0');
      const s = String(timerSeconds % 60).padStart(2, '0');
      timerEl.textContent = `${m}:${s}`;
      if (timerSeconds <= 0) {
        clearInterval(timerInterval);
        timerEl.textContent = 'scaduto';
        timerEl.style.color = '#e30613';
      }
    }, 1000);
  }

  payBtn.addEventListener('click', () => {
    const formatted = fmt(getTotal());
    modalAmount.textContent       = formatted;
    modalAmountMobile.textContent = formatted;
    phoneAmount.textContent       = formatted;
    successAmount.textContent     = formatted;
    successRef.textContent        = randomRef();
    stepPayment.style.display = '';
    stepSuccess.style.display = 'none';
    modalBackdrop.classList.add('open');
    startTimer();
  });

  function closeModal() {
    modalBackdrop.classList.remove('open');
    clearInterval(timerInterval);
  }

  document.getElementById('modalCloseBtn').addEventListener('click', closeModal);
  modalBackdrop.addEventListener('click', e => { if (e.target === modalBackdrop) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  function showSuccess() {
    clearInterval(timerInterval);
    stepPayment.style.display = 'none';
    stepSuccess.style.display = '';
  }
  document.getElementById('simulateBtn').addEventListener('click', showSuccess);
  document.getElementById('simulateBtnMobile').addEventListener('click', showSuccess);

  document.getElementById('successCloseBtn').addEventListener('click', () => {
    closeModal();
    [...cart.keys()].forEach(id => removeFromCart(id));
  });

  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const tab = btn.dataset.tab;
      document.getElementById('panelQR').style.display     = tab === 'qr'     ? '' : 'none';
      document.getElementById('panelMobile').style.display = tab === 'mobile' ? '' : 'none';
    });
  });

  renderCart();
</script>
