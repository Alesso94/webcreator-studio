<script>
  // ===== STATE =====
  const cart = new Map(); // id -> {name, price, qty}
  let timerInterval = null;
  let timerSeconds = 120;

  // ===== REFS =====
  const productsGrid     = document.getElementById('productsGrid');
  const cartItems        = document.getElementById('cartItems');
  const cartEmpty        = document.getElementById('cartEmpty');
  const cartFooter       = document.getElementById('cartFooter');
  const cartTotal        = document.getElementById('cartTotal');
  const headerCartCount  = document.getElementById('headerCartCount');
  const sidebarCartCount = document.getElementById('sidebarCartCount');
  const payBtn           = document.getElementById('payBtn');
  const modalBackdrop    = document.getElementById('modalBackdrop');
  const modalAmount      = document.getElementById('modalAmount');
  const modalAmountMobile= document.getElementById('modalAmountMobile');
  const phoneAmount      = document.getElementById('phoneAmount');
  const successAmount    = document.getElementById('successAmount');
  const successRef       = document.getElementById('successRef');
  const timerEl          = document.getElementById('timer');
  const stepPayment      = document.getElementById('stepPayment');
  const stepSuccess      = document.getElementById('stepSuccess');

  // ===== HELPERS =====
  function fmt(n) { return '€' + n.toFixed(2).replace('.', ','); }
  function getTotal() { let t = 0; cart.forEach(i => t += i.price * i.qty); return t; }
  function getCount() { let c = 0; cart.forEach(i => c += i.qty); return c; }
  function randomRef() { return 'STW-' + Math.random().toString(36).slice(2,8).toUpperCase(); }

  // ===== RENDER CART =====
  function renderCart() {
    const count = getCount();
    const total = getTotal();

    headerCartCount.textContent  = count;
    sidebarCartCount.textContent = count;

    if (cart.size === 0) {
      cartEmpty.style.display  = '';
      cartItems.style.display  = 'none';
      cartFooter.style.display = 'none';
    } else {
      cartEmpty.style.display  = 'none';
      cartItems.style.display  = '';
      cartFooter.style.display = '';

      cartItems.innerHTML = '';
      cart.forEach((item, id) => {
        const row = document.createElement('div');
        row.className = 'cart-item';
        row.innerHTML = `
          <span class="cart-item-name">${item.name}${item.qty > 1 ? ` ×${item.qty}` : ''}</span>
          <span class="cart-item-price">${fmt(item.price * item.qty)}</span>
          <button class="cart-item-remove" data-id="${id}" aria-label="Rimuovi">✕</button>
        `;
        cartItems.appendChild(row);
      });
    }
    cartTotal.textContent = fmt(total);
  }

  // ===== ADD / REMOVE =====
  function addToCart(id, name, price) {
    if (cart.has(id)) {
      cart.get(id).qty++;
    } else {
      cart.set(id, { name, price: parseFloat(price), qty: 1 });
    }
    document.getElementById(`card-${id}`).classList.add('in-cart');
    const btn = document.querySelector(`.product-add-btn[data-id="${id}"]`);
    if (btn) btn.textContent = '✓ Aggiunto';
    renderCart();
  }

  function removeFromCart(id) {
    cart.delete(id);
    const card = document.getElementById(`card-${id}`);
    if (card) {
      card.classList.remove('in-cart');
      const btn = card.querySelector('.product-add-btn');
      if (btn) btn.textContent = '+ Aggiungi al carrello';
    }
    renderCart();
  }

  // ===== EVENTS: products =====
  productsGrid.addEventListener('click', e => {
    const btn = e.target.closest('.product-add-btn');
    if (!btn) return;
    const card = btn.closest('.product-card');
    addToCart(card.dataset.id, card.dataset.name, card.dataset.price);
  });

  // ===== EVENTS: cart remove =====
  cartItems.addEventListener('click', e => {
    const btn = e.target.closest('.cart-item-remove');
    if (btn) removeFromCart(btn.dataset.id);
  });

  // ===== TIMER =====
  function startTimer() {
    timerSeconds = 120;
    clearInterval(timerInterval);
    timerInterval = setInterval(() => {
      timerSeconds--;
      const m = String(Math.floor(timerSeconds / 60)).padStart(2, '0');
      const s = String(timerSeconds % 60).padStart(2, '0');
      timerEl.textContent = `${m}:${s}`;
      if (timerSeconds <= 0) {
        clearInterval(timerInterval);
        timerEl.textContent = 'scaduto';
        timerEl.style.color = 'var(--red)';
      }
    }, 1000);
  }

  // ===== MODAL OPEN =====
  payBtn.addEventListener('click', () => {
    const total = getTotal();
    const formatted = fmt(total);
    modalAmount.textContent       = formatted;
    modalAmountMobile.textContent = formatted;
    phoneAmount.textContent       = formatted;
    successAmount.textContent     = formatted;
    successRef.textContent        = randomRef();
    stepPayment.style.display = '';
    stepSuccess.style.display = 'none';
    modalBackdrop.classList.add('open');
    startTimer();
  });

  // ===== MODAL CLOSE =====
  function closeModal() {
    modalBackdrop.classList.remove('open');
    clearInterval(timerInterval);
    timerEl.textContent = '02:00';
    timerEl.style.color = '';
    timerSeconds = 120;
  }

  document.getElementById('modalCloseBtn').addEventListener('click', closeModal);
  modalBackdrop.addEventListener('click', e => { if (e.target === modalBackdrop) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  // ===== SIMULATE SUCCESS =====
  function showSuccess() {
    clearInterval(timerInterval);
    stepPayment.style.display = 'none';
    stepSuccess.style.display = '';
  }
  document.getElementById('simulateBtn').addEventListener('click', showSuccess);
  document.getElementById('simulateBtnMobile').addEventListener('click', showSuccess);

  document.getElementById('successCloseBtn').addEventListener('click', () => {
    closeModal();
    // Reset cart
    const ids = [...cart.keys()];
    ids.forEach(id => removeFromCart(id));
  });

  // ===== TABS =====
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const tab = btn.dataset.tab;
      document.getElementById('panelQR').style.display     = tab === 'qr'     ? '' : 'none';
      document.getElementById('panelMobile').style.display = tab === 'mobile' ? '' : 'none';
    });
  });

  // ===== MOBILE: scroll cart into view on header cart btn =====
  document.getElementById('cartToggleBtn').addEventListener('click', () => {
    document.getElementById('cartSidebar').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  });

  // init
  renderCart();
</script>

</body>
</html>
