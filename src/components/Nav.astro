---
const navLinks = [
  { href: '/servizi', label: 'Servizi' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/blog', label: 'Blog' },
  { href: '/contatti', label: 'Contatti' },
];

const currentPath = Astro.url.pathname;
---

<header class="nav">
  <div class="nav-inner">
    <a href="/" class="logo">
      WebCreator<strong>Studio</strong>
    </a>

    <nav class="nav-links">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <a href="/contatti" class="nav-cta">Parliamo →</a>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 64px;
    z-index: 1000;
    background: rgba(11, 11, 10, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo {
    font-family: var(--sans);
    font-size: 1.05rem;
    font-weight: 300;
    color: var(--text);
    letter-spacing: -0.01em;
    flex-shrink: 0;
    text-decoration: none;
  }

  .logo strong {
    font-weight: 600;
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    font-family: var(--sans);
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--accent);
    transition: width 0.25s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .nav-cta {
    flex-shrink: 0;
    padding: 0.5rem 1.25rem;
    border: 1px solid var(--border-strong);
    border-radius: 4px;
    font-family: var(--sans);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .nav-cta:hover {
    background: var(--accent-dim);
    border-color: var(--accent);
  }

  @media (max-width: 900px) {
    .nav-links {
      display: none;
    }

    .nav-inner {
      padding: 0 24px;
    }
  }

  @media (max-width: 480px) {
    .nav-cta {
      padding: 0.4rem 1rem;
      font-size: 0.8rem;
    }
  }
</style>
