  { id:6,  name:"Aceto Balsamico di Modica",      price:16.00, category:"Oli & Aceti", rating:4.8, reviews:44,  badge:"Premium" },
  { id:7,  name:"Malvasia delle Lipari 375ml",    price:19.50, category:"Vini",       rating:4.9, reviews:38,  badge:"Raro" },
  { id:8,  name:"Torrone di Caltanissetta",       price:11.00, category:"Dolci",      rating:4.4, reviews:92,  badge:null },
  { id:9,  name:"Pecorino Stagionato 300g",       price:13.50, category:"Formaggi",   rating:4.7, reviews:71,  badge:"DOP" },
  { id:10, name:"Olive Nocellara del Belice",     price:7.50,  category:"Conserve",   rating:4.6, reviews:188, badge:null },
  { id:11, name:"Limoncello di Sicilia 500ml",    price:15.00, category:"Vini",       rating:4.5, reviews:55,  badge:null },
