              <rect x="120" y="20" width="20" height="20" rx="1" fill="#e30613"/>

              <rect x="8" y="108" width="44" height="44" rx="4" fill="#e30613"/>
              <rect x="14" y="114" width="32" height="32" rx="2" fill="white"/>
              <rect x="20" y="120" width="20" height="20" rx="1" fill="#e30613"/>

              <!-- QR data modules (simulated) -->
              <g fill="#e30613" opacity="0.85">
                <rect x="60" y="8" width="8" height="8"/><rect x="72" y="8" width="8" height="8"/><rect x="84" y="8" width="8" height="8"/>
                <rect x="60" y="20" width="8" height="8"/><rect x="84" y="20" width="8" height="8"/>
                <rect x="60" y="32" width="8" height="8"/><rect x="72" y="32" width="8" height="8"/>
                <rect x="8" y="60" width="8" height="8"/><rect x="20" y="60" width="8" height="8"/><rect x="44" y="60" width="8" height="8"/>
                <rect x="8" y="72" width="8" height="8"/><rect x="32" y="72" width="8" height="8"/>
                <rect x="20" y="84" width="8" height="8"/><rect x="44" y="84" width="8" height="8"/>
                <rect x="60" y="60" width="8" height="8"/><rect x="72" y="60" width="8" height="8"/><rect x="84" y="60" width="8" height="8"/><rect x="96" y="60" width="8" height="8"/>
                <rect x="60" y="72" width="8" height="8"/><rect x="84" y="72" width="8" height="8"/>
