];

const categories = ["Tutti", "Conserve", "Oli & Aceti", "Vini", "Dolci", "Formaggi"];

const categoryGradients: Record<string, string> = {
  "Conserve":   "linear-gradient(135deg, #2d1f0e, #1a1614)",
  "Oli & Aceti":"linear-gradient(135deg, #1a2d0e, #141a14)",
  "Vini":       "linear-gradient(135deg, #2d0e1a, #1a1416)",
  "Dolci":      "linear-gradient(135deg, #2d200e, #1a1814)",
  "Formaggi":   "linear-gradient(135deg, #2d2a0e, #1a1a14)",
};

const categoryIcons: Record<string, string> = {
  "Conserve":   "🫙",
  "Oli & Aceti":"🫒",
  "Vini":       "🍷",
  "Dolci":      "🍮",
  "Formaggi":   "🧀",
};

function renderStars(rating: number): string {
  const full  = Math.round(rating);
  const empty = 5 - full;
  return "★".repeat(full) + "☆".repeat(empty);
}
